{
  "name": "enhanced-copy-monorepo",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build:cdn && npm run build --workspaces --if-present",
    "build:cdn": "node scripts/build-cdn.mjs",
    "package:extension": "npm run build -w apps/extension && node scripts/package-extension.mjs",
    "dev": "npm run dev -w apps/demo",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc -p tsconfig.base.json --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/chrome": "^0.1.4",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.0",
    "esbuild": "^0.27.0",
    "jsdom": "^27.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.2",
    "vitest": "^4.0.8"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
